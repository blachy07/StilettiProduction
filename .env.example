# Supabase (Project Settings -> API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Anon/publishable key — sicura da esporre al browser (protetta da RLS), usata
# per gli upload diretti su Supabase Storage via TUS
SUPABASE_ANON_KEY=

# Segreto per firmare i token di accesso PIN dei clienti (stringa lunga e casuale, es. `openssl rand -hex 32`)
CONSEGNA_SECRET=

# Segreto per firmare i cookie di sessione admin — DEVE essere diverso da CONSEGNA_SECRET
ADMIN_SECRET=

# Credenziali di accesso al pannello /admin
ADMIN_USERNAME=
# Formato "salt_hex:hash_hex", generato una volta sola (vedi documentazione nella Fase 3)
ADMIN_PASSWORD_HASH=
